{
  "DataConfig": {
    "base_dir": "Dataset",
    "combined_name": "all_combined",
    "datasets": [
      "acl_2017",
      "iclr_2017",
      "arxiv.cs.ai_2007-2017",
      "arxiv.cs.cl_2007-2017",
      "arxiv.cs.lg_2007-2017",
      "conll_2016"
    ],
    "splits": ["train", "dev", "test"],
    "reviews_subdir": "reviews",
    "parsed_subdir": "parsed_pdfs",
    "output_subdir": "dataset"
  },
  "PreprocessConfig": {
    "methods": [
      "build_corpus_words",
      "compute_frequency_buckets"
    ],
    "only_char": true,
    "lower": true,
    "stop_remove": true,
    "hfw_proportion": 0.01,
    "freq_proportion": 0.05,
    "min_freq_threshold": 3,
    "allow_recommendation_fallback": true,
    "recommendation_threshold": 3.5,
    "preserve_corpus_cache": true,
    "shuffle_seed": 42
  },
  "FeatureConfig": {
    "methods": [
      "handcrafted_features"
    ],
    "max_vocab": false,
    "encoder_type": "w2v",
    "use_hand_features": true,
    "drop_post_review_leakage": true
  },
  "TrainingConfig": {
    "enabled": true,
    "data_dir": null,
    "preprocess_methods": [],
    "model": "RandomForestClassifier",
    "model_param": {
      "balance": true,
      "n_estimators": 300,
      "max_depth": 10,
      "min_samples_leaf": 2,
      "random_state": 42
    }
  }
}
